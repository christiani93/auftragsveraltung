# Server-Konfiguration fuer Auftragsverwaltung.
# Diese Datei auf dem Server nach .env kopieren und Werte anpassen.
# NIE in Git/OneDrive einchecken!

# Secret Key fuer Session-Cookies — mit `python -c "import secrets; print(secrets.token_hex(32))"` erzeugen
AUFTRAGSVERWALTUNG_SECRET_KEY=BITTE_HIER_LANGER_ZUFAELLIGER_STRING_REIN

# Initialer Admin-User (wird beim ersten Start angelegt, dann kannst du diese Vars wieder leeren)
AUFTRAGSVERWALTUNG_ADMIN_USER=admin
AUFTRAGSVERWALTUNG_ADMIN_PASSWORD=BITTE_HIER_STARKES_PASSWORT

# Firma-Name fuer Header und PDFs (optional)
AUFTRAGSVERWALTUNG_FIRMA=Mein Elektrobetrieb

# Sicheres Session-Cookie ueber HTTPS (in Production immer 1)
AUFTRAGSVERWALTUNG_HTTPS_ONLY=1
